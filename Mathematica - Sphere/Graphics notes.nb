Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Graphics3D", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"GeometricTransformation", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"Blue", ",", 
          RowBox[{"Sphere", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", "1"}], "]"}], ",",
           "Red", ",", 
          RowBox[{"Sphere", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "1.2", ",", "0"}], "}"}], ",", "0.1"}], 
           "]"}]}], "}"}], ",", 
        RowBox[{"Composition", "[", 
         RowBox[{
          RowBox[{"TranslationTransform", "[", 
           RowBox[{"{", 
            RowBox[{"x", ",", "y", ",", "1"}], "}"}], "]"}], ",", 
          RowBox[{"RotationTransform", "[", 
           RowBox[{"z", ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], "]"}], ",", 
          RowBox[{"(*", 
           RowBox[{"Yaw", " ", 
            RowBox[{"(", 
             RowBox[{"Z", "-", 
              RowBox[{"axis", " ", "rotation"}]}], ")"}]}], "*)"}], 
          RowBox[{"RotationTransform", "[", 
           RowBox[{"x", ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", "1", ",", "0"}], "}"}]}], "]"}], ",", 
          RowBox[{"RotationTransform", "[", 
           RowBox[{"y", ",", 
