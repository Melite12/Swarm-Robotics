Cell[BoxData[
 RowBox[{
  RowBox[{"Manipulate", "[", 
   RowBox[{
    RowBox[{"Graphics3D", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"GeometricTransformation", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"Blue", ",", 
           RowBox[{"Sphere", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "0", ",", "1"}], "}"}], ",", "1"}], "]"}], 
           ",", 
           RowBox[{"(*", 
            RowBox[{"Main", " ", "rolling", " ", "sphere"}], "*)"}], 
           "\[IndentingNewLine]", "Red", ",", 
           RowBox[{"Sphere", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "0", ",", "2.0"}], "}"}], ",", "0.1"}], 
            "]"}]}], " ", 
          RowBox[{"(*", 
           RowBox[{"Marker", " ", "on", " ", "top"}], "*)"}], "}"}], ",", 
         RowBox[{"Composition", "[", 
          RowBox[{
           RowBox[{"TranslationTransform", "[", 
            RowBox[{"{", 
             RowBox[{"x", ",", "y", ",", "0"}], "}"}], "]"}], ",", 
           RowBox[{"(*", 
            RowBox[{"Move", " ", "the", " ", "ball", " ", "to", " ", 
             RowBox[{"(", 
