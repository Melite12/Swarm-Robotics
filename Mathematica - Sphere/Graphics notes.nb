Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Object", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x_", ",", "y_"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Alpha]_", ",", "\[Beta]_", ",", "\[Gamma]_"}], "}"}], ",", 
     "t_"}], "]"}], ":=", 
   RowBox[{"GeometricTransformation", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Opacity", "@", ".3"}], ",", 
         RowBox[{"Sphere", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", "1"}], "]"}]}], 
        "}"}], ",", "Black", ",", 
       RowBox[{"Sphere", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"0.5", " ", 
            RowBox[{"Cos", "[", "t", "]"}]}], ",", 
           RowBox[{"0.5", " ", 
            RowBox[{"Sin", "[", "t", "]"}]}], ",", 
           RowBox[{"-", "0.5"}]}], "}"}], ",", "0.05"}], "]"}]}], "}"}], ",", 
     RowBox[{"TransformationFunction", "[", 
      RowBox[{"ArrayFlatten", "@", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"EulerMatrix", "[", 
            RowBox[{"{", 
             RowBox[{"\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]"}], "}"}], 
            "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", "x", "}"}], ",", 
             RowBox[{"{", "y", "}"}], ",", 
             RowBox[{"{", "1", "}"}]}], "}"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"{", 
             RowBox[{"0", ",", "0", ",", "0"}], "}"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"{", "1", "}"}], "}"}]}], "}"}]}], "}"}]}], "]"}]}], 
    "]"}]}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{"Graphics3D", "[", 
  RowBox[{
   RowBox[{"Object", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"2", ",", "3"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Pi", "/", "6"}], ",", 
       RowBox[{"Pi", "/", "6"}], ",", 
       RowBox[{"Pi", "/", "6"}]}], "}"}], ",", "0"}], "]"}], ",", " ", 
   RowBox[{"Axes", " ", "->", " ", "True"}]}], "]"}], "\n"}], "Input",
