           RowBox[{"RotationTransform", "[", 
            RowBox[{"x", ",", 
             RowBox[{"{", 
              RowBox[{"0", ",", "1", ",", "0"}], "}"}]}], "]"}], ",", 
           RowBox[{"(*", 
            RowBox[{"Rotate", " ", "around", " ", "Y", " ", 
             RowBox[{"(", 
              RowBox[{"rolling", " ", "forward"}], ")"}]}], "*)"}], 
           RowBox[{"RotationTransform", "[", 
            RowBox[{"y", ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "1"}], ",", "0", ",", "0"}], "}"}]}], "]"}]}], 
          "  ", 
          RowBox[{"(*", 
           RowBox[{"Rotate", " ", "around", " ", "X", " ", 
            RowBox[{"(", 
             RowBox[{"sideways", " ", "rolling"}], ")"}]}], "*)"}], "]"}]}], 
        "]"}], "}"}], ",", 
      RowBox[{"Axes", "->", "True"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", 
      RowBox[{"2", " ", "Pi"}], ",", "0.01"}], "}"}], ",", 
    RowBox[{"{", 
