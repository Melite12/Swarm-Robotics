Cell[CellGroupData[{

Cell[BoxData[
 TemplateBox[<|"query" -> "picture of sheep", "boxes" -> RowBox[{
      TemplateBox[{"\"sheep\"", 
        RowBox[{"Entity", "[", 
          RowBox[{"\"TaxonomicSpecies\"", ",", "\"OvisAries::4t8r2\""}], 
          "]"}], "\"Entity[\\\"TaxonomicSpecies\\\", \
\\\"OvisAries::4t8r2\\\"]\"", "\"species specification\""}, "Entity"], "[", 
      TemplateBox[{"\"image\"", 
        RowBox[{"EntityProperty", "[", 
          RowBox[{"\"TaxonomicSpecies\"", ",", "\"Image\""}], "]"}], 
        "\"EntityProperty[\\\"TaxonomicSpecies\\\", \\\"Image\\\"]\""}, 
       "EntityProperty"], "]"}], 
   "allassumptions" -> {{
     "word" -> "", "template" -> 
      "Assuming \"picture\" is referring to species${separator}Use as ${desc} \
or ${desc} instead${separator}Use the input as ${desc}", "count" -> "4", 
      "pulldown" -> "false", "type" -> "MultiClash", "default" -> 
      "{\"MC\", \"\"} -> {\"TaxonomicSpeciesPropertyClass\", \"dflt\"}", 
      "Values" -> {{
        "name" -> "TaxonomicSpeciesPropertyClass", "desc" -> 
         " referring to species", "input" -> 
         "{\"MC\", \"\"} -> {\"TaxonomicSpeciesPropertyClass\"}", "word" -> 
         "picture"}, {
        "name" -> "FoodProperty", "desc" -> " referring to food items", 
         "input" -> "{\"MC\", \"\"} -> {\"FoodProperty\"}", "word" -> 
         "picture"}, {
        "name" -> "FoodPropertyClass", "desc" -> " referring to food items", 
         "input" -> "{\"MC\", \"\"} -> {\"FoodPropertyClass\"}", "word" -> 
         "picture"}, {
        "name" -> "WordData", "desc" -> " referring to English words", 
         "input" -> "{\"MC\", \"\"} -> {\"WordData\"}", "word" -> 
         "the input"}}}}, "assumptions" -> {}, "open" -> {1, 2}, 
   "querystate" -> {
    "Online" -> True, "Allowed" -> True, "mparse.jsp" -> 
     1.365528`7.586845603223151, "Messages" -> {}}, "contextinfo" -> 
   Automatic, "version" -> 5|>,
  "LinguisticAssistantTemplate"]], "Input",
 CellChangeTimes->{3.9472073685199337`*^9},
 CellLabel->"In[54]:=",ExpressionUUID->"943b5ad5-e449-624c-bf5c-0337cda513e7"],

